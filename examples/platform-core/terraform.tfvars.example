location    = "southcentralus"
suffix      = "01"

vnet_address_space = [
  "10.10.0.0/16",
]

app_subnet_address_prefixes = [
  "10.10.1.0/24",
]

data_subnet_address_prefixes = [
  "10.10.2.0/24",
]

common_nsg_rules = [
  {
    priority                   = 100
    direction                  = "Inbound"
    access                     = "Allow"
    protocol                   = "Tcp"
    source_port_range          = "*"
    destination_port_range     = "443"
    source_address_prefix      = "*"
    destination_address_prefix = "*"
  }
]

app_custom_nsg_rules = []

data_custom_nsg_rules = []

common_udr_routes = [
  {
    address_prefix = "0.0.0.0/0"
    next_hop_type  = "Internet"
  }
]

app_custom_udr_routes = []

data_custom_udr_routes = []
